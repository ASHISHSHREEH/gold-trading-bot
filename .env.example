# ============================================================
# MT5 CONNECTION
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================
MT5_LOGIN=your_mt5_login_id
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server_name

# ============================================================
# TRADING CONFIG
# ============================================================
MT5_SYMBOL=XAUUSD
MT5_MAGIC=20240101
MT5_SLIPPAGE=20

# ============================================================
# ACCOUNT TYPE: DEMO or LIVE
# ============================================================
ACCOUNT_TYPE=DEMO
