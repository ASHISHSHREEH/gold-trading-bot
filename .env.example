# MT5 Connection
MT5_LOGIN=123456
MT5_PASSWORD=your_password
MT5_SERVER=FxPro-Demo
MT5_PATH=

# Account settings
ACCOUNT_TYPE=DEMO
MT5_MAGIC=20240101
MT5_SLIPPAGE=20

# Symbols (comma-separated)
MT5_SYMBOLS=GOLD,#USSPX500,#US100_M26,#Japan225

# Account currency FX rate — units of your account currency per 1 USD.
# JPY account: set to your broker's current USD/JPY rate (e.g. 158).
# USD account: set to 1.0 (default).
# The bot fetches the live rate from MT5 automatically; this is the fallback.
ACCOUNT_FX_RATE=158.0
